## Local demo environment variables (copy to secrets.env and fill values)
## This file is safe to commit. Do NOT commit your real secrets.env.

# ---------------------------------------------------------------------------
# Required: AWS
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=ap-southeast-2

# ---------------------------------------------------------------------------
# Required for wiz-enabled runs (enable_wiz=true)
# ---------------------------------------------------------------------------
WIZ_CLIENT_ID=REPLACE_ME
WIZ_CLIENT_SECRET=REPLACE_ME

# ---------------------------------------------------------------------------
# Optional but recommended for Wiz Code-to-Cloud container mapping
# ---------------------------------------------------------------------------
WIZ_CLI_CLIENT_ID=REPLACE_ME
WIZ_CLI_CLIENT_SECRET=REPLACE_ME

# ---------------------------------------------------------------------------
# Required for full wiz-enabled connector + sensor behavior
# ---------------------------------------------------------------------------
TF_VAR_wiz_tenant_id=REPLACE_ME
TF_VAR_wiz_trusted_arn=arn:aws:iam::REPLACE_ME:role/REPLACE_ME
TF_VAR_wiz_client_environment=prod
TF_VAR_tenant_image_pull_username=REPLACE_ME
TF_VAR_tenant_image_pull_password=REPLACE_ME

# ---------------------------------------------------------------------------
# Required if you want direct browser access to frontend from your machine
# ---------------------------------------------------------------------------
# JSON list string (example uses a placeholder CIDR):
TF_VAR_allowed_cidrs=["203.0.113.10/32"]

# Optional: if your tenant uses different Wiz scanner CIDRs than repo defaults,
# override scanner ranges and/or include them in TF_VAR_allowed_cidrs.
# TF_VAR_dynamic_scanner_ipv4s_develop="54.153.167.0/32,54.206.253.144/32"

# Optional helper for local deploys:
# AUTO_DETECT_PUBLIC_IP=true
